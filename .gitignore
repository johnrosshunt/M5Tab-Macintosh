# Documentation and ROM files (large binaries)
docs/

# PlatformIO
.pio/
.pioenvs/
.piolibdeps/

# Build directories
.build/
build/
release/

# IDE settings
.vscode/.browse.c_cpp.db*
.vscode/c_cpp_properties.json
.vscode/launch.json
.vscode/ipch

# Clangd
.cache/

# Compiled files
*.o
*.elf
*.bin
*.hex
*.map

# Library dependencies (managed by PlatformIO)
lib/*/
# ...except our vendored dependencies for the Waveshare build, which must
# be tracked so the Waveshare env builds out of the box.
!lib/esp32_p4_wifi6_touch_lcd_x/
!lib/esp32_p4_wifi6_touch_lcd_x/**
!lib/esp_lcd_jd9365/
!lib/esp_lcd_jd9365/**
!lib/esp_lcd_touch/
!lib/esp_lcd_touch/**
!lib/esp_lcd_touch_gt911/
!lib/esp_lcd_touch_gt911/**
!lib/esp_codec_dev/
!lib/esp_codec_dev/**

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~

# IDE and editor files
*.swp
*.swo
*.swn
.idea/
*.sublime-project
*.sublime-workspace

# Logs
*.log

# Temporary files
*.tmp
*.temp

# Secrets and credentials (if any)
secrets.h
credentials.h

# idf_component.yml at project root is generated per-env by
# scripts/select_component_yml.py from idf_component_{tab5,waveshare}.yml.
idf_component.yml

# Asset headers emitted by scripts/build_assets.py from ./assets at pre-build.
src/generated/
