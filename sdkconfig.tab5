# M5Stack Tab5 sdkconfig overrides.
#
# These Kconfig settings are merged on top of the pioarduino Arduino defaults
# when building the [env:esp32p4_pioarduino] environment. Currently the only
# override is enabling the TinyUSB MSC class so the pre-boot "USB Disk" mode
# in src/basilisk/usb_msc.cpp can expose the SD card as a Mass Storage device.
#
# On Tab5 the USB-OTG port is shared between Arduino's CDC (serial) and the
# TinyUSB MSC driver; only one class is active at a time. Entering USB Disk
# mode temporarily detaches CDC and attaches MSC, both automatically restored
# when the user taps "Done".

# --- TinyUSB for the pre-boot "USB Disk" (MSC) mode ---
CONFIG_TINYUSB_MSC_ENABLED=y
CONFIG_TINYUSB_MSC_BUFSIZE=8192

# --- FatFs: future-proofing for exFAT support ---
# pioarduino currently ships its FatFs precompiled with FF_FS_EXFAT=0,
# so these settings are no-ops today (the linked archive overrides them).
# We declare them anyway so that if/when pioarduino enables exFAT in a
# future framework release, our build picks it up automatically without
# needing another firmware change. board_sd_tab5.cpp's exFAT probe is
# what surfaces the current limitation to users in the meantime.
CONFIG_FATFS_USE_EXFAT=y
CONFIG_FATFS_LFN_HEAP=y
CONFIG_FATFS_MAX_LFN=255
